#!/usr/bin/env bash
# This script displays numbers 1 to 20 with specific cultural superstitious messages
n=1
while [ "$n" -le 20 ]
do
    case "$n" in
        4)
            echo "$n"
            echo "bad luck from China"
            ;;
        9)
            echo "$n"
            echo "bad luck from Japan"
            ;;
        17)
            echo "$n"
            echo "bad luck from Italy"
            ;;
        *)
            echo "$n"
            ;;
    esac
    n=$((n + 1))
done
